{
  "$schema": "https://raw.githubusercontent.com/nicedozie4u/tauri-2/main/core/tauri-config-schema/schema.json",
  "productName": "DayLife",
  "version": "0.1.0",
  "identifier": "com.24kchengye.daylife",
  "build": {
    "frontendDist": "../frontend",
    "devUrl": "http://127.0.0.1:8263",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "windows": [],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
